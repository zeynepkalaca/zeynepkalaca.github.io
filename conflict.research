<html>
<head>
<title>conflict.research</title>
<style>
  body { font-family: "Helvetica", Arial, sans-serif; background: white; margin: 40px; line-height: 1.4; }
  a { color: blue; text-decoration: underline; }
  
  /* Dashboard Interface */
  .control-panel { background: #f9f9f9; padding: 15px; border: 1px solid #000; margin-bottom: 20px; }
  select, button { padding: 5px; font-family: monospace; border: 1px solid #000; background: #fff; cursor: pointer; }
  
  .data-table { width: 100%; border-collapse: collapse; margin-top: 20px; font-size: 13px; }
  .data-table th { background: #000; color: #fff; text-align: left; padding: 8px; font-family: monospace; }
  .data-table td { padding: 8px; border-bottom: 1px solid #ddd; }
  
  .metric-badge { display: inline-block; background: #fff5f5; border: 1px dashed red; padding: 10px; margin-bottom: 20px; font-family: monospace; }
  .loading-msg { font-family: monospace; color: blue; font-style: italic; }
</style>
</head>
<body>

  <h1>conflict_data_explorer.sh</h1>
  <p><a href="index.html">back home</a></p>
  <hr>

  <p style="font-size: 13px; max-width: 650px;">
    <strong>live api link:</strong> executing real-time queries against the uppsala conflict data program (ucdp) database. filtering metrics for state-based conflict, dyad intersections, and estimated civilian/one-sided fatalities within specified geographic boundaries.
  </p>

  <!-- Live API Status Card -->
  <div class="metric-badge">
    DATABASE STATUS: <span id="api-status" class="loading-msg">fetching live ucdp records...</span><br>
    TOTAL RECORDED FATALITIES (FILTERED): <span id="total-fatalities" style="font-weight:bold; color:red; display:none;">0</span>
  </div>

  <!-- UCDP Live Filters -->
  <div class="control-panel">
    <strong>query controls:</strong>
    <select id="typeFilter" onchange="processAndDisplayData()">
      <option value="all">all conflict types</option>
      <option value="state-based">state-based violence (side a vs side b)</option>
      <option value="one-sided">one-sided violence (vs civilians)</option>
    </select>
  </div>

  <!-- Dynamic Data Grid -->
  <table class="data-table">
    <thead>
      <tr>
        <th>year</th>
        <th>dyad / actors involved</th>
        <th>location</th>
        <th>best estimate fatalities</th>
        <th>type</th>
      </tr>
    </thead>
    <tbody id="api-rows">
      <!-- Live API Rows will inject here -->
    </tbody>
  </table>

  <br><br>
  <p style="font-size: 11px; color: gray;">data pipeline: powered by the uppsala conflict data program (ucdp) API v1.0. dataset updates dynamically depending on standard data cleaning windows by research staff at uppsala university.</p>

  <script>
    // Global variable to hold raw API data locally once loaded
    let globalConflictRecords = [];

    // URL targets Turkey as location (GWNO Country Code 640)
    const ucdpApiUrl = "https://ucdpapi.pcr.uu.se/api/gedevents/1.0?Country=640";

    // Async function to fetch from Uppsala University
    async function fetchUcdpData() {
      try {
        const response = await fetch(ucdpApiUrl);
        if (!response.ok) throw new Error("network check failed");
        
        const data = await response.json();
        
        // UCDP wraps results in a "Result" array property
        globalConflictRecords = data.Result || [];
        
        // Update dashboard status
        document.getElementById('api-status').innerText = "online // records loaded sync";
        document.getElementById('api-status').style.color = "green";
        document.getElementById('total-fatalities').style.display = "inline";
        
        // Render rows
        processAndDisplayData();
      } catch (error) {
        console.error("API Error:", error);
        document.getElementById('api-status').innerText = "offline // error reading data pipeline";
        document.getElementById('api-status').style.color = "red";
      }
    }

    function processAndDisplayData() {
      const typeFilterValue = document.getElementById('typeFilter').value;
      const tableBody = document.getElementById('api-rows');
      tableBody.innerHTML = ""; // reset UI
      
      let runningFatalitiesCount = 0;

      // Handle raw incoming metrics
      globalConflictRecords.forEach(event => {
        // Map UCDP Type IDs to readable string definitions
        let displayType = "state-based";
        if (event.type_of_violence === 3) displayType = "one-sided";
        if (event.type_of_violence === 2) displayType = "non-state";

        // Filter Evaluation
        const matchesType = (typeFilterValue === "all" || displayType === typeFilterValue);

        if (matchesType) {
          const deaths = event.best || 0;
          runningFatalitiesCount += deaths;

          // Build row output securely stringified
          const rowHTML = `<tr>
            <td style="font-family: monospace;">${event.year || 'n/a'}</td>
            <td><strong>${event.side_a || 'unknown'}</strong> vs. ${event.side_b || 'unknown'}</td>
            <td>${event.adm_1 || event.country || 'unspecified region'}</td>
            <td style="color: red; font-weight: bold; font-family: monospace;">${deaths}</td>
            <td style="font-style: italic; font-size: 11px; text-transform: uppercase;">${displayType}</td>
          </tr>`;
          
          tableBody.innerHTML += rowHTML;
        }
      });

      // Render updated context summary
      document.getElementById('total-fatalities').innerText = runningFatalitiesCount;
    }

    // Trigger async pipeline compilation on window boot
    window.onload = fetchUcdpData;
  </script>

</body>
</html>
